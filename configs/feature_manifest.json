{
  "coverage_goal": "100% public feature-family mapping for requested products, with separate product-ready coverage tracked from implementation evidence.",
  "coverage_scoring": {
    "contract": {
      "feature_family_mapping": "Tracks whether each requested public feature family is represented by built-in code, external-client adapters, CLI/GUI workflows, platform scripts, or plugin extension points.",
      "product_ready_coverage": "Tracks implementation maturity separately so adapter-backed, optional, CLI-only, GUI-only, shell, script, and seam-backed features are not overstated as fully product-ready."
    },
    "feature_family_method": "Weighted feature-family mapping. Each feature family counts equally for every product it maps to. Built-in implementations, external adapters, optional implementations, CLI features, GUI features and platform scripts score as mapped; documented seams score partial credit until implemented.",
    "product_ready_method": "Evidence-weighted product readiness. Each feature family counts equally for every product it maps to, but maturity weights distinguish built-in implementations from adapter-backed, optional, shell, script, documented, or extension-seam features.",
    "feature_family_mapping_target_percent": 100,
    "product_ready_target_percent": 100,
    "feature_family_status_weights": {
      "adapter-seam": 0.25,
      "docs-adapter": 0.2,
      "gui-shell": 0.4,
      "implemented": 1.0,
      "implemented-adapter": 1.0,
      "implemented-cli": 1.0,
      "implemented-cli-gui": 1.0,
      "implemented-gui": 1.0,
      "implemented-optional": 1.0,
      "implemented-shell": 1.0,
      "manifest-seam": 0.15,
      "plugin-seam": 0.2,
      "script-seam": 0.15
    },
    "product_ready_status_weights": {
      "adapter-seam": 0.25,
      "docs-adapter": 0.2,
      "gui-shell": 0.4,
      "implemented": 1.0,
      "implemented-adapter": 0.75,
      "implemented-cli": 0.85,
      "implemented-cli-gui": 0.9,
      "implemented-gui": 0.85,
      "implemented-optional": 0.75,
      "implemented-shell": 0.45,
      "manifest-seam": 0.15,
      "plugin-seam": 0.2,
      "script-seam": 0.15
    },
