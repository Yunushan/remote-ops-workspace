FROM python:3.12-slim
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    ROW_HOME=/data
WORKDIR /app
COPY . /app
RUN pip install --no-cache-dir --no-compile .
RUN useradd --create-home --uid 10001 --shell /usr/sbin/nologin row \
    && mkdir -p /data \
    && chown -R row:row /app /data
USER 10001:10001
EXPOSE 8765
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD python -c "from urllib.request import urlopen; urlopen('http://127.0.0.1:8765/healthz', timeout=3).read()"
CMD ["row", "serve-web", "--host", "0.0.0.0", "--port", "8765", "--allow-public-bind"]
