{
  "schema_version": 1,
  "release_tag_pattern": "v<project.version>",
  "workflow": ".github/workflows/release.yml",
  "policy": {
    "default_github_release": "Only assets under default_github_release are uploaded by the default core release lane.",
    "protected_platform_promotion": "Verified Linux i386/armhf and Windows XP native-host assets are attached only by the opt-in protected promotion lane after accepted evidence passes.",
    "script_supported_native": "These targets have maintained build-script mappings, but require matching builders and are not uploaded by the default GitHub release workflow.",
    "source_or_remote_only": "These targets receive source/install/Web/PWA assets or can be managed as remote endpoints; they are not native app artifacts in the default workflow."
  },
  "default_github_release": {
    "source_and_python": {
      "job": "source-and-python",
      "artifacts": [
        "remote_ops_workspace-1.0.8-py3-none-any.whl",
        "remote_ops_workspace-1.0.8.tar.gz",
        "remote-ops-workspace-v1.0.8-release-manifest.json",
        "remote-ops-workspace-v1.0.8-SHA256SUMS.txt"
      ],
      "target_bundles": [
        "remote-ops-workspace-v1.0.8-source.zip",
        "remote-ops-workspace-v1.0.8-windows.zip",
        "remote-ops-workspace-v1.0.8-linux.tar.gz",
        "remote-ops-workspace-v1.0.8-macos.tar.gz",
        "remote-ops-workspace-v1.0.8-bsd.tar.gz",
        "remote-ops-workspace-v1.0.8-solaris.tar.gz",
        "remote-ops-workspace-v1.0.8-android-termux.tar.gz",
        "remote-ops-workspace-v1.0.8-web-pwa.zip"
      ]
    },
    "native_jobs": [
      {
        "job": "windows-native",
        "platform": "windows",
        "platform_target_ids": [
          "windows-x86",
          "windows-x64",
          "windows-arm64"
        ],
        "arches": [
          "x86",
          "x64",
          "arm64"
        ],
        "upload_artifact_prefix": "release-windows-native-",
        "asset_patterns": [
          "remote-ops-workspace-v1.0.8-windows-<x86|x64|arm64>-setup.exe",
          "remote-ops-workspace-v1.0.8-windows-<x86|x64|arm64>.msi",
          "remote-ops-workspace-v1.0.8-windows-<x86|x64|arm64>-native.zip",
          "remote-ops-workspace-v1.0.8-windows-<x86|x64|arm64>-native-manifest.json",
          "remote-ops-workspace-v1.0.8-windows-<x86|x64|arm64>-native-SHA256SUMS.txt"
        ]
      },
      {
        "job": "macos-native",
        "platform": "macos",
        "platform_target_ids": [
          "macos-x64",
          "macos-arm64"
        ],
        "arches": [
          "x64",
          "arm64"
        ],
        "upload_artifact_prefix": "release-macos-native-",
        "asset_patterns": [
          "remote-ops-workspace-v1.0.8-macos-<x64|arm64>.dmg",
          "remote-ops-workspace-v1.0.8-macos-<x64|arm64>.pkg",
          "remote-ops-workspace-v1.0.8-macos-<x64|arm64>-native-manifest.json",
          "remote-ops-workspace-v1.0.8-macos-<x64|arm64>-native-SHA256SUMS.txt"
        ]
      },
      {
        "job": "linux-native",
        "platform": "linux",
        "platform_target_ids": [
          "linux-x86_64",
          "linux-arm64"
        ],
        "arches": [
          "x86_64",
          "aarch64"
        ],
        "upload_artifact_prefix": "release-linux-native-",
        "asset_patterns": [
          "remote-ops-workspace-v1.0.8-linux-<amd64|arm64>.deb",
          "remote-ops-workspace-v1.0.8-linux-<x86_64|aarch64>.rpm",
          "remote-ops-workspace-v1.0.8-linux-<x86_64|aarch64>.AppImage",
          "remote-ops-workspace-v1.0.8-linux-<x86_64|aarch64>-native.tar.gz",
          "remote-ops-workspace-v1.0.8-linux-<x86_64|aarch64>-native-manifest.json",
          "remote-ops-workspace-v1.0.8-linux-<x86_64|aarch64>-native-SHA256SUMS.txt"
        ]
      }
    ]
  },
  "protected_platform_promotion": {
    "workflow_input": "include_protected_platform_evidence",
    "evidence_job": "accepted-platform-evidence-assets",
    "publish_job": "publish-protected-platform-evidence",
    "targets": [
      "linux-i386",
      "linux-armhf",
      "windows-xp-native-x86",
      "windows-xp-native-x64"
    ]
  },
  "script_supported_native": [
    {
      "platform_target_id": "linux-i386",
      "platform": "linux",
      "cpu_arch": "i386/i686",
      "script": "scripts/make_linux_native.sh",
      "asset_patterns": [
        "remote-ops-workspace-v1.0.8-linux-i386.deb",
        "remote-ops-workspace-v1.0.8-linux-i686.rpm",
        "remote-ops-workspace-v1.0.8-linux-i686.AppImage",
        "remote-ops-workspace-v1.0.8-linux-i686-native.tar.gz",
        "remote-ops-workspace-v1.0.8-linux-i686-native-manifest.json",
        "remote-ops-workspace-v1.0.8-linux-i686-native-SHA256SUMS.txt"
      ],
      "builder_requirement": "Run on a real 32-bit i386/i686 host, matching 32-bit container, or self-hosted runner where builder evidence reports dpkg --print-architecture=i386, getconf LONG_BIT=32, rpm installed and sudo -n true passing, with Python, PyInstaller, dpkg, dpkg-deb, getconf, rpm, rpmbuild and appimagetool support.",
      "promotion_policy": "May be attached to a release only after a maintainer runs and verifies the matching builder output."
    },
    {
      "platform_target_id": "linux-armhf",
      "platform": "linux",
      "cpu_arch": "armv7l/armhf",
      "script": "scripts/make_linux_native.sh",
      "asset_patterns": [
        "remote-ops-workspace-v1.0.8-linux-armhf.deb",
        "remote-ops-workspace-v1.0.8-linux-armv7hl.rpm",
        "remote-ops-workspace-v1.0.8-linux-armhf.AppImage",
        "remote-ops-workspace-v1.0.8-linux-armhf-native.tar.gz",
        "remote-ops-workspace-v1.0.8-linux-armhf-native-manifest.json",
        "remote-ops-workspace-v1.0.8-linux-armhf-native-SHA256SUMS.txt"
      ],
      "builder_requirement": "Run on a real 32-bit armv7l/armhf host, matching 32-bit container, or self-hosted runner where builder evidence reports dpkg --print-architecture=armhf, getconf LONG_BIT=32, rpm installed and sudo -n true passing, with Python, PyInstaller, dpkg, dpkg-deb, getconf, rpm, rpmbuild and appimagetool support.",
      "promotion_policy": "May be attached to a release only after a maintainer runs and verifies the matching builder output."
    }
  ],
  "source_or_remote_only": [
    {
      "id": "android-termux",
      "platform_target_ids": [
        "android-armv7",
        "android-arm64"
      ],
      "default_assets": [
        "remote-ops-workspace-v1.0.8-android-termux.tar.gz",
        "remote-ops-workspace-v1.0.8-web-pwa.zip"
      ],
      "native_status": "No APK is published until a tested native Android wrapper exists."
    },
    {
      "id": "ios-web-pwa",
      "platform_target_ids": [
        "ios-web"
      ],
      "default_assets": [
        "remote-ops-workspace-v1.0.8-web-pwa.zip"
      ],
      "native_status": "No IPA/App Store package is published until a tested native iOS wrapper exists."
    },
    {
      "id": "bsd",
      "default_assets": [
        "remote-ops-workspace-v1.0.8-bsd.tar.gz"
      ],
      "native_status": "Source/install bundle plus CLI/Web/PWA workflows; no default native installer."
    },
    {
      "id": "solaris-illumos",
      "default_assets": [
        "remote-ops-workspace-v1.0.8-solaris.tar.gz"
      ],
      "native_status": "Source/install bundle plus CLI/Web/PWA workflows; no default native installer."
    },
    {
      "id": "windows-legacy-remote-targets",
      "windows_legacy_target_versions": [
        "Windows XP",
        "Windows Vista",
        "Windows 7",
        "Windows 8",
        "Windows 8.1"
      ],
      "native_status": "Legacy Windows versions can be managed as remote targets; Windows XP x86/x64 remote endpoints use isolated per-profile legacy opt-ins, while modern native releases target Windows 10/11 and supported Server hosts."
    }
  ]
}
